@baseUrl = http://localhost:3000

### Auth login
# @name authLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept: application/json

{
    "email": "user1@email.com",
    "password": "123456"
}

### Read one user
# @name readOneUser
GET {{baseUrl}}/user/456

### Create user
# @name createUser
POST {{baseUrl}}/user
Content-Type: application/json

{
  "name": "Luis Henrique",
  "email": "user1@email.com",
  "password": "123456"
}
